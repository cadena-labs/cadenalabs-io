{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cadenalabs-io-dev",
  "main": "./server/app.ts",
  "compatibility_date": "2026-04-27",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "html_handling": "none",
    "not_found_handling": "none",
  },
  "secrets": {
    "required": [
      "RESEND_API_KEY",
      "RESEND_FROM_EMAIL",
      "RESEND_FROM_NAME",
      "CONTACT_EMAIL",
      "TURNSTILE_SITE_KEY",
      "TURNSTILE_SECRET_KEY",
    ],
  },
  "limits": {
    "cpu_ms": 10000,
  },
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": false,
      "persist": true,
      "head_sampling_rate": 0.25,
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 0.25,
    },
  },
}
