# Runtime secrets — required for the contact form and Turnstile verification.
# In production these are uploaded to the Worker via `pnpm run deploy:with-secrets`
# (driven by 1Password). Locally, copy this file to `.dev.vars` and fill in.
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
RESEND_FROM_NAME="Cadena Labs"
CONTACT_EMAIL=""
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Cloudflare Workers Builds variables — supplied via Cloudflare project settings,
# not in `.dev.vars`. Listed here for documentation only.
# OP_SERVICE_ACCOUNT_TOKEN=
# OP_ENVIRONMENT_ID=
