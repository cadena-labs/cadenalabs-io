# Runtime secrets — required for the contact form and Turnstile verification.
# In production these are uploaded to the Worker via `pnpm run deploy:with-secrets`
# (driven by 1Password). Locally, copy `.dev.vars.example` to `.dev.vars` and fill in.
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
RESEND_FROM_NAME="Cadena Labs"
CONTACT_EMAIL=""
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# 1Password Environments — resolve via MCP (list_environments → cadenalabs-io)
# or 1Password desktop (Copy environment ID), then export for `pnpm run dev:op`.
# CADENALABS_DEV_1PASSWORD_ENVIRONMENT_ID=
# OP_SERVICE_ACCOUNT_TOKEN and OP_ENVIRONMENT_ID are for Cloudflare Workers Builds only.
