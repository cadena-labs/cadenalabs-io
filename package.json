{
  "name": "cadenalabs-io",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "react-router build",
    "build:production": "CLOUDFLARE_VITE_WRANGLER_CONFIG_PATH=wrangler.jsonc react-router build",
    "build:with-required-secrets": "pnpm run assert:runtime-secrets && pnpm run build:production",
    "assert:runtime-secrets": "node ./scripts/assert-runtime-secrets.mjs",
    "check": "turbo run format:check lint typecheck test build && pnpm audit --prod",
    "cloudflare:build": "node ./scripts/cloudflare-build.mjs",
    "cloudflare:deploy": "./scripts/install-op.sh && ./scripts/with-op-environment.sh pnpm run deploy:with-secrets",
    "deploy": "pnpm run build:production && pnpm run deploy:built",
    "deploy:1password": "pnpm run cloudflare:build && pnpm run cloudflare:deploy",
    "deploy:built": "wrangler deploy --config dist/server/wrangler.json",
    "deploy:with-secrets": "node ./scripts/wrangler-runtime-secrets.mjs deploy",
    "dev": "CLOUDFLARE_INCLUDE_PROCESS_ENV=true react-router dev",
    "dev:op": "op run --environment \"${CADENALABS_DEV_1PASSWORD_ENVIRONMENT_ID:?Set CADENALABS_DEV_1PASSWORD_ENVIRONMENT_ID to the Cadena Labs dev Environment ID}\" -- pnpm dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "og:generate": "node ./scripts/generate-og-image.mjs",
    "preview": "pnpm run build && vite preview --host 0.0.0.0",
    "preview:op": "op run --environment \"${CADENALABS_DEV_1PASSWORD_ENVIRONMENT_ID:?Set CADENALABS_DEV_1PASSWORD_ENVIRONMENT_ID to the Cadena Labs dev Environment ID}\" -- pnpm preview",
    "secrets:sync": "node ./scripts/sync-cloudflare-secrets.mjs",
    "secrets:sync:1password": "./scripts/install-op.sh && ./scripts/with-op-environment.sh pnpm run secrets:sync",
    "test": "node --test --experimental-strip-types --no-warnings=ExperimentalWarning \"tests/**/*.test.ts\"",
    "typecheck": "react-router typegen && pnpm run wrangler:types && tsc --noEmit",
    "wrangler:types": "wrangler types worker-configuration.d.ts --config dev.wrangler.jsonc --env-file /dev/null"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/mona-sans": "^5.2.8",
    "@react-router/cloudflare": "7.16.0",
    "@ridemountainpig/svgl-react": "^1.0.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isbot": "5.1.43",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "7.16.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.40.1",
    "@cloudflare/workers-types": "4.20260611.1",
    "@eslint/js": "^9.39.4",
    "@react-router/dev": "7.17.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "satori": "^0.26.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.2.4",
    "turbo": "2.9.18",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "8.0.16",
    "wrangler": "4.99.0"
  }
}
