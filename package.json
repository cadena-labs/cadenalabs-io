{
  "name": "cadenalabs-io",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "pnpm": {
    "overrides": {
      "ws@>=8.0.0 <8.20.1": ">=8.20.1"
    }
  },
  "scripts": {
    "build": "node ./scripts/cloudflare-vite.mjs react-router build",
    "build:with-required-secrets": "pnpm run assert:runtime-secrets && pnpm run build",
    "assert:runtime-secrets": "node ./scripts/assert-runtime-secrets.mjs",
    "check": "turbo run format:check lint typecheck test build && pnpm audit --prod",
    "cloudflare:build": "./scripts/install-op.sh && ./scripts/with-op-environment.sh pnpm run build:with-required-secrets",
    "cloudflare:deploy": "./scripts/install-op.sh && ./scripts/with-op-environment.sh pnpm run deploy:with-secrets",
    "cloudflare:preview": "./scripts/install-op.sh && ./scripts/with-op-environment.sh pnpm run versions:upload:with-secrets",
    "deploy": "pnpm run build && pnpm run deploy:built",
    "deploy:1password": "pnpm run cloudflare:build && pnpm run cloudflare:deploy",
    "deploy:built": "wrangler deploy --config dist/server/wrangler.json",
    "deploy:with-secrets": "node ./scripts/wrangler-runtime-secrets.mjs deploy",
    "dev": "node ./scripts/cloudflare-vite.mjs vite --host 0.0.0.0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "og:generate": "node ./scripts/generate-og-image.mjs",
    "preview": "pnpm run build && node ./scripts/cloudflare-vite.mjs vite preview --host 0.0.0.0",
    "secrets:sync": "node ./scripts/sync-cloudflare-secrets.mjs",
    "secrets:sync:1password": "./scripts/install-op.sh && ./scripts/with-op-environment.sh pnpm run secrets:sync",
    "test": "node --test --experimental-strip-types --no-warnings=ExperimentalWarning \"tests/**/*.test.ts\"",
    "typecheck": "node ./scripts/cloudflare-vite.mjs react-router typegen && pnpm run wrangler:types && tsc --noEmit",
    "versions:upload": "wrangler versions upload --config dist/server/wrangler.json",
    "versions:upload:with-secrets": "node ./scripts/wrangler-runtime-secrets.mjs versions upload",
    "wrangler:types": "wrangler types --include-runtime false"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/mona-sans": "^5.2.8",
    "@react-router/cloudflare": "7.14.2",
    "@ridemountainpig/svgl-react": "^1.0.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isbot": "5.1.40",
    "lucide-react": "^1.11.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "7.14.2",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260516.1",
    "@cloudflare/vite-plugin": "1.33.2",
    "@eslint/js": "^9.39.4",
    "@react-router/dev": "7.14.2",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "satori": "^0.26.0",
    "tailwindcss": "^4.2.4",
    "turbo": "2.9.14",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "8.0.10",
    "wrangler": "4.85.0"
  }
}
